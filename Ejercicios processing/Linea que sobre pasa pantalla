
PVector pos,vel;

void setup(){
 size(600,600);
 pos=new PVector(width/3,height/2);
 vel=new PVector(1,-1);
    
}
void draw(){
 pos.add(vel);
 limitar();
 line(pos.x,pos.y,pos.x,pos.y);
  
}

void limitar(){
 if(pos.x>=width){
   pos.x=pos.x*0;}
   if(pos.y<=0 || pos.y>=height){
     pos.y=pos.y*-1;}
  
  
}
